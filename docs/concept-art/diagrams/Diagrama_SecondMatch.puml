@startuml Diagrama_SecondMatch
title Diagrama de Clases - Escena SecondMatch

abstract class MatchScene <<PyGameScene>> {
  + __init__(director)
  + on_exit()
  + events(event_list)
  + update(delta_time)
  + render(screen)

  # _get_config()
  # _create_boundaries()
  # _create_goals()
  # _render_field(screen)
  # _init_extras()
  # _on_powerup_collected()
  # _on_powerup_activate()
  # _render_field_fg(screen)
  # _on_goal()
  # _reset_positions()
}

class SecondScene {
  - boss : MotoMoto
  - contact_listener : Scene2ContactListener
  - clouds : List
  - teleport_flash_timer : float
  - kick_flash_timer : float

  # _get_config()
  # _init_extras()
  # _create_boundaries()
  # _create_goals()
  # _on_powerup_collected()
  # _on_powerup_activate()
  # _reset_positions()
  + update(delta_time)
  + render(screen)

  - _update_boss_ai(delta_time)
  - _update_clouds(delta_time)
  - _spawn_cloud()
  - _render_field(screen)
  - _render_field_fg(screen)
  - _draw_clouds(screen)
}

class Scene2ContactListener <<Box2D.b2ContactListener>> {
  - scene : SecondScene
  - _pending_bounces : List
  + BeginContact(contact)
  + EndContact(contact)
  + apply_pending_bounces() : Set
  - _get_cloud_contact(contact)
}

class RocketFactory <<Static>> {
  + create_element(tipo, world, pos, subtipo)
  + create_cloud(world, x, y, w, h, friction, restitution)
  + create_goals(...)
  + create_boundaries(...)
  + destroy_body(world, body)
}

class MotoMoto {
  + body : b2Body
  + is_angry : bool
  + angry_timer : float
  + update_logic(dt)
  + update_fsm(ball_pos, player_pos, goal_x_right)
  + try_teleport_to_goal(ball_pos, tx, ty)
}

MatchScene <|-- SecondScene
SecondScene *-- Scene2ContactListener
Scene2ContactListener --> SecondScene : scene
SecondScene ..> RocketFactory : usa
SecondScene --> MotoMoto : boss
@enduml