@startuml ComponentesManagers
skinparam componentStyle uml2
skinparam shadowing false
skinparam monochrome false
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 60

title Diagrama de Componentes del Paquete Managers

package "Managers" {
    component "AssetsManager" as Assets <<Caché>>
    component "SettingsManager" as Settings <<IO>>
    component "DialogueManager" as Dialogue <<Parser>>
}

component "Director / Scenes" as Core <<Core>>
component "Ficheros Locales" as Files <<JSON / PNG / MP3>>

' Relaciones internas
Dialogue ..> Assets : <<usa para imágenes>>

' Dependencias de Ficheros
Assets ..up.> Files : <<carga diferida>>
Settings ..up.> Files : <<lee/escribe config.json>>
Dialogue ..up.> Files : <<parsea diálogos>>

' Relaciones con el Core
Core ..> Settings : <<consulta estado>>
Core ..> Assets : <<pide recursos>>
Core ..> Dialogue : <<delega narrativa>>

@enduml