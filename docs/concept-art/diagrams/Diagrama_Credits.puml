@startuml Diagrama_CreditsScene
title Diagrama de Clases - Escena CreditsScene

abstract class PyGameScene {
  + director : Director
  + fade_alpha : float
  + fade_to_black(callback)
  + fade_from_black()
  + update_fade(dt)
  + draw_fade(screen)
  + {abstract} update(dt)
  + {abstract} render(screen)
  + {abstract} events(event_list)
}

class CreditsScene {
  - background : Surface
  - scroll_speed : float
  - y_offset : float
  - total_height : float
  - credits_list : List
  - rendered_texts : List<Surface>
  - is_exiting : bool
  - wait_timer : float
  - font_role : Font
  - font_name : Font

  + __init__(director)
  + update(dt)
  + render(screen)
  + events(event_list)
  
  - _prepare_credits() : List<Surface>
  - _start_exit_transition()
  - _set_wait_timer()
  - _exit_game_completely()
}

class Assets <<Static>> {
    + _IMAGE_DATA : Dict
    + get_image(key) : Surface
}

class ScreenSettings <<Static>> {
    + SCREEN_WIDTH : int
    + SCREEN_HEIGHT : int
}

class GUISettings <<Static>> {
    + FONT_TEXT : String
}

PyGameScene <|-- CreditsScene
CreditsScene ..> Assets : usa
CreditsScene ..> ScreenSettings : consulta
CreditsScene ..> GUISettings : consulta

@enduml